auto-install-peers=false
strict-peer-dependencies=false

# Include optional native binaries for all target platforms in the lockfile.
# Without this, pnpm records darwin/win32 packages as '-' when run on Linux
# (Replit/CI), causing "Cannot find module @rollup/rollup-darwin-arm64" on Mac.
supportedArchitectures[os][]=linux
supportedArchitectures[os][]=darwin
supportedArchitectures[cpu][]=x64
supportedArchitectures[cpu][]=arm64
